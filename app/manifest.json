{
  "manifest_version": 3,
  "name": "Champ Build Finder",
  "short_name": "Champ Build Finder",
  "description": "Find a champions build quickly and consistently on your favorite build recommendation websites.",
  "version": "1.0.1",
  "author": "Starswept Development",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
    },
    "default_popup": "/popup/popup.html",
    "default_title": "Champ Build Finder"
  },
"background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "omnibox": { "keyword": "build" },
  "permissions": [
    "storage"
  ],
  "offline_enabled": false
}